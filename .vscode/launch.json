{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(Windows) Launch Game (LLDB)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/publish/game.exe",
            "args": [],
            "cwd": "${workspaceFolder}/publish",
            "console": "integratedTerminal",
            //"preLaunchTask": "CMake: Build Game (Debug)"
        },
        {
            "name": "(Windows) Launch Game",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/publish/game.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/publish",
            "environment": [],
            "console": "integratedTerminal",
            //"preLaunchTask": "CMake: Build Game (Debug)",
            "logging": {
                "trace": false,
                "traceResponse": false,
                "engineLogging": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "clear": true
            }
        },
        {
            "name": "(Windows) Attach to Game",
            "type": "cppvsdbg",
            "request": "attach",
            "processId": "${command:pickProcess}"
        }
    ]
}