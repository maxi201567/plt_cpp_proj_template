{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Create Venv",
            "type": "shell",
            "command": "if not exist build\\py_temp\\Scripts\\python.exe python -m venv build/py_temp",
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/c"]
                }
            }
        },
        {
            "label": "Setup",
            "type": "shell",
            "command": "build\\py_temp\\Scripts\\python.exe .vscode\\dependency.py",
            "dependsOn": ["Create Venv"],
            "dependsOrder": "sequence",
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "CMake: Configure Game (MSVC)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B", "build",
                "-A", "x64",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "CMake: Configure Game (Ninja)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B", "build",
                "-G", "Ninja",
                "-DCMAKE_MAKE_PROGRAM=${workspaceFolder}/3rd/ninja/ninja.exe",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "CMake: Build Game (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "build",
                "--config", "Debug",
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": [
                "$msCompile"
            ]
        },
        {
            "label": "CMake: Build Game (Release)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "build",
                "--config", "Release",
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": [
                "$msCompile"
            ]
        },
        {
            "label": "Delete Build Directory (Windows)",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "rmdir /s /q build"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "windows": {}
        },
        {
            "label": "Delete Build Directory (Unix)",
            "type": "shell",
            "command": "rm",
            "args": [
                "-rf", "build"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "linux": {},
            "osx": {}
        },
        {
            "label": "CMake: Clean Game Build (cmake)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "build",
                "--target", "clean"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Clean Game Build",
            "dependsOn": [
                "CMake: Clean Game Build (cmake)",
                "Delete Build Directory (Windows)",
                "Delete Build Directory (Unix)"
            ],
            "problemMatcher": []
        },
        {
            "label": "CMake: Build 3rd Party (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "build",
                "--target", "Build_3rd",
                "--config", "Debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "CMake: Build 3rd Party (Release)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "build",
                "--target", "Build_3rd",
                "--config", "Release"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}