{
    "version": "2.0.0",
    "inputs": [
        {
            "id": "build_config",
            "type": "pickString",
            "description": "Select Build Config",
            "options": [
                "Debug",
                "Release"
            ],
            "default": "Debug"
        }
    ],
    "tasks": [
        {
            "label": "_internal_create_venv",
            "type": "shell",
            "command": "if not exist build\\py_temp\\Scripts\\python.exe python -m venv build/py_temp",
            "hide": true,
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "cmd.exe",
                    "args": [
                        "/c"
                    ]
                }
            }
        },
        {
            "label": "Setup",
            "type": "shell",
            "command": "build\\py_temp\\Scripts\\python.exe .vscode\\dependency.py",
            "dependsOn": [
                "_internal_create_venv"
            ],
            "dependsOrder": "sequence",
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "_internal_config_proj_msvc",
            "type": "shell",
            "command": "cmake",
            "hide": true,
            "args": [
                "-B",
                "build",
                "-A",
                "x64",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "_internal_config_proj_ninja",
            "type": "shell",
            "command": "cmake",
            "hide": true,
            "args": [
                "-B",
                "build",
                "-G",
                "Ninja",
                "-DCMAKE_MAKE_PROGRAM=${workspaceFolder}/3rd/ninja/ninja.exe",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        // Config Main Entry
        {
            "label": "Config Project",
            "type": "shell",
            "command": "cmake",
            "windows": {
                "dependsOn": [
                    "_internal_config_proj_msvc"
                ]
            },
            "linux": {
                "dependsOn": [
                    "_internal_config_proj_ninja"
                ]
            }
        },
        // Build Main Entry
        {
            "label": "Build Project",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--config",
                "${input:build_config}",
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": [
                "$msCompile"
            ]
        },
        // Build 3rd Main Entry
        {
            "label": "Build 3rd Party",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--target",
                "Build_3rd",
                "--config",
                "${input:build_config}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "_internal_clear_build_dir_windows",
            "type": "shell",
            "command": "cmd",
            "hide": true,
            "args": [
                "/c",
                "rmdir /s /q build"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "windows": {}
        },
        {
            "label": "_internal_clear_build_dir_linux",
            "type": "shell",
            "command": "rm",
            "hide": true,
            "args": [
                "-rf",
                "build"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "linux": {},
            "osx": {}
        },
        {
            "label": "_internal_clean_cmake",
            "type": "shell",
            "command": "cmake",
            "hide": true,
            "args": [
                "--build",
                "build",
                "--target",
                "clean"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        // Clean Build Main Entry
        {
            "label": "Clean Game Build",
            "dependsOn": [
                "_internal_clean_cmake",
                "_internal_clear_build_dir_windows",
                "_internal_clear_build_dir_linux"
            ],
            "problemMatcher": []
        }
    ]
}